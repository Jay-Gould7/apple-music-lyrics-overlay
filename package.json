{
  "name": "apple-music-floating-lyrics",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "desktop:dev": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:1420 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:1420 electron .\"",
    "desktop:start": "electron .",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "desktop:build": "npm run build",
    "desktop:dist": "npm run dist"
  },
  "dependencies": {
    "opencc-js": "^1.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.5.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.applemusic.floatinglyrics",
    "productName": "Apple Music Floating Lyrics",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "scripts/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts/get-media-state.ps1",
        "to": "scripts/get-media-state.ps1"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
